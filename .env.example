# === VAYVE — Environment ===
# Lokal als .env.local, in Produktion als .env.production (von docker-compose geladen).

# Session-Cookie-Signatur (hochentropisch, stabil lassen — sonst werden alle ausgeloggt)
# erzeugen mit:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Admin-Passwort als bcrypt-Hash (NICHT das Klartext-Passwort)
# erzeugen mit:  node -e "console.log(require('bcryptjs').hashSync('DEIN_PASSWORT', 10))"
ADMIN_PASSWORD_HASH=

# Optional: Speicherort für DB + Uploads (Default: ./data lokal, /app/data im Container)
# DATA_DIR=/app/data
# DATABASE_PATH=/app/data/vayve.db
# UPLOADS_DIR=/app/data/uploads
